<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Y2K CYBER-GALLERY 2026</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=VT323&display=swap" rel="stylesheet">
    
    <!-- THƯ VIỆN FIREBASE (BẮT BUỘC PHẢI CÓ ĐỦ 3 DÒNG NÀY) -->
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>

    <style>
        :root { --p: #ff00ff; --b: #00f0ff; --g: #39ff14; --win: #c0c0c0; }
        
        body {
            background: #000; color: #fff; font-family: 'VT323', monospace; margin: 0; padding: 0;
            background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
            background-size: 20px 20px;
        }

        /* Scanline CRT Effect */
        body::after {
            content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18,16,16,0) 50%, rgba(0,0,0,0.1) 50%);
            background-size: 100% 4px; z-index: 9999; pointer-events: none;
        }

        .container { max-width: 500px; margin: 0 auto; padding: 10px; }

        /* Window Style */
        .window {
            background: var(--win); border: 3px solid; border-color: #fff #808080 #808080 #fff;
            padding: 4px; box-shadow: 8px 8px 0px var(--p); color: #000; margin-bottom: 20px;
        }
        .title-bar {
            background: linear-gradient(90deg, #000080, #1084d0); color: white;
            padding: 3px 10px; display: flex; justify-content: space-between;
            font-family: 'Syncopate', sans-serif; font-size: 10px;
        }

        /* Gallery Area */
        .film-strip {
            background: #111; border: 3px inset #fff; min-height: 400px;
            position: relative; overflow: hidden; padding: 20px 10px;
        }
        .polaroid {
            background: #fff; padding: 8px 8px 30px; margin-bottom: 30px;
            box-shadow: 5px 5px 0px var(--b); position: relative;
        }
        .polaroid img { width: 100%; display: block; border: 1px solid #000; }

        /* Sticker System */
        .stk-wrap { position: absolute; z-index: 100; touch-action: none; padding: 5px; }
        .stk-wrap.edit-mode { border: 2px dashed var(--p); cursor: move; }
        .stk-img { width: 100%; height: 100%; pointer-events: none; }
        
        .stk-btn {
            position: absolute; width: 24px; height: 24px; background: #fff;
            border: 2px solid #000; display: none; align-items: center; justify-content: center;
            font-weight: bold; cursor: pointer; font-size: 14px;
        }
        .stk-del { top: -12px; right: -12px; color: red; }
        .stk-res { bottom: -12px; right: -12px; color: blue; cursor: nwse-resize; }
        .edit-mode .stk-btn { display: flex; }

        /* Buttons */
        .btn-y2k {
            background: var(--win); border: 3px solid; border-color: #fff #808080 #808080 #fff;
            padding: 10px; font-family: 'VT323'; font-size: 1.2rem; cursor: pointer;
            width: 100%; text-transform: uppercase; margin-top: 5px;
        }
        .btn-y2k:active { border-color: #808080 #fff #fff #808080; }
        .active-mode { background: var(--g) !important; box-shadow: 0 0 10px var(--g); }

        /* Drawer */
        .drawer {
            position: fixed; bottom: 0; left: 0; right: 0; background: var(--win);
            border-top: 4px solid #fff; z-index: 2000; height: 350px; display: none;
            flex-direction: column; box-shadow: 0 -5px 20px rgba(0,0,0,0.5);
        }
        .stk-grid {
            display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
            padding: 15px; overflow-y: auto; background: #fff; flex-grow: 1;
        }
        .stk-grid img { width: 100%; cursor: pointer; border: 1px solid #ccc; }
    </style>
</head>
<body>

<div class="container">
    <div class="window">
        <div class="title-bar"><span>Y2K_OS_v2.6</span><span>[?] [X]</span></div>
        <div id="lock-screen" style="padding: 40px 10px; text-align: center;">
            <p>SYSTEM LOCKED // ENTER CODE</p>
            <input type="password" id="passInput" style="width:80%; padding:10px; background:#000; color:var(--g); border:2px solid var(--g); font-family:'VT323'; font-size:1.5rem; text-align:center;">
            <button class="btn-y2k" onclick="unlock()">ACCESS SYSTEM</button>
        </div>

        <div id="main-screen" style="display:none; padding: 5px;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
                <button class="btn-y2k" onclick="document.getElementById('fileInp').click()">💾 +PHOTO</button>
                <button class="btn-y2k" onclick="toggleDrawer()">🌈 +STICKER</button>
                <button id="editToggle" class="btn-y2k" style="grid-column: span 2;" onclick="toggleEdit()">EDIT MODE: OFF</button>
            </div>

            <div id="film-strip" class="film-strip">
                <div id="gallery"></div>
            </div>
            <p id="status" style="font-size:12px; color:#000; text-align:center; margin:0;">SYS_READY // 150_SLOTS_FREE</p>
        </div>
    </div>
</div>

<div id="drawer" class="drawer">
    <div style="background:#000080; color:#fff; padding:5px 10px; display:flex; justify-content:space-between;">
        <b>STICKER_WAREHOUSE_2026</b>
        <button onclick="toggleDrawer()">CLOSE [X]</button>
    </div>
    <div class="stk-grid" id="stk-grid"></div>
</div>

<input type="file" id="fileInp" accept="image/*" style="display:none" onchange="uploadImage()">

<script>
    // --- CONFIG ---
    const firebaseConfig = {
        apiKey: "AIzaSyA8-ctuFLh3DuB68g180CEux7iZ2ZKqYMU",
        authDomain: "lovetouching-a8981.firebaseapp.com",
        projectId: "lovetouching-a8981",
        appId: "1:325823794583:web:6b190f660d75b7e547c8d2"
    };
    const CLOUD_NAME = "dvvso2wpc";
    const UPLOAD_PRESET = "stodjvzb";

    // --- INITIALIZE ---
    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();
    const urlParams = new URLSearchParams(window.location.search);
    const chipId = urlParams.get('id') || 'y2k_demo';

    let currentImages = [], currentStickers = [], isEdit = false;

    // Sticker Assets (Tăng cường 200 items bằng cách loop)
    const ASSET_BASE = [
        'https://api.iconify.design/noto:clown-face.svg', 'https://api.iconify.design/noto:moai.svg', 
        'https://api.iconify.design/noto:alien.svg', 'https://api.iconify.design/noto:sparkles.svg',
        'https://api.iconify.design/logos:chrome.svg', 'https://api.iconify.design/noto:cat-face.svg',
        'https://api.iconify.design/noto:videocassette.svg', 'https://api.iconify.design/noto:floppy-disk.svg'
    ];

    async function unlock() {
        const pass = document.getElementById('passInput').value;
        const doc = await db.collection('toys').doc(chipId).get();
        const data = doc.exists ? doc.data() : {password: "1234", images: [], stickers: []};
        
        if (pass === data.password) {
            currentImages = data.images || [];
            currentStickers = data.stickers || [];
            if(!doc.exists) await db.collection('toys').doc(chipId).set(data);
            
            document.getElementById('lock-screen').style.display = 'none';
            document.getElementById('main-screen').style.display = 'block';
            renderGallery();
            renderStickers();
            initDrawer();
        } else { alert("WRONG KEY!"); }
    }

    function toggleEdit() {
        isEdit = !isEdit;
        const btn = document.getElementById('editToggle');
        btn.innerText = isEdit ? "EDIT MODE: ON" : "EDIT MODE: OFF";
        btn.classList.toggle('active-mode', isEdit);
        renderStickers(); renderGallery();
    }

    function initDrawer() {
        const grid = document.getElementById('stk-grid');
        grid.innerHTML = "";
        for(let i=0; i<100; i++) { // Render 100 items demo
            const url = ASSET_BASE[i % ASSET_BASE.length];
            const img = document.createElement('img');
            img.src = url;
            img.onclick = () => { addSticker(url); toggleDrawer(); };
            grid.appendChild(img);
        }
    }

    function toggleDrawer() {
        const d = document.getElementById('drawer');
        d.style.display = (d.style.display === 'flex') ? 'none' : 'flex';
    }

    function addSticker(url) {
        currentStickers.push({ url: url, x: 50, y: 50, w: 100 });
        save(); renderStickers();
    }

    function renderStickers() {
        document.querySelectorAll('.stk-wrap').forEach(s => s.remove());
        currentStickers.forEach((stk, idx) => {
            const wrap = document.createElement('div');
            wrap.className = `stk-wrap ${isEdit ? 'edit-mode' : ''}`;
            wrap.style.left = stk.x + 'px'; wrap.style.top = stk.y + 'px';
            wrap.style.width = stk.w + 'px';
            wrap.innerHTML = `<img src="${stk.url}" class="stk-img">
                              <div class="stk-btn stk-del" onclick="deleteStk(${idx})">X</div>
                              <div class="stk-btn stk-res">⤢</div>`;
            if(isEdit) makeInteract(wrap, idx);
            document.getElementById('film-strip').appendChild(wrap);
        });
    }

    function makeInteract(el, idx) {
        let isDrag = false, isRes = false, sx, sy, sw;
        el.onmousedown = el.ontouchstart = (e) => {
            const p = e.touches ? e.touches[0] : e;
            if(e.target.classList.contains('stk-res')) isRes = true; else isDrag = true;
            sx = p.clientX; sy = p.clientY; sw = el.offsetWidth;
            e.stopPropagation();
        };
        window.onmousemove = window.ontouchmove = (e) => {
            if(!isDrag && !isRes) return;
            const p = e.touches ? e.touches[0] : e;
            if(isDrag) {
                const nx = el.offsetLeft + (p.clientX - sx);
                const ny = el.offsetTop + (p.clientY - sy);
                el.style.left = nx + 'px'; el.style.top = ny + 'px';
                currentStickers[idx].x = nx; currentStickers[idx].y = ny;
            } else {
                const nw = sw + (p.clientX - sx);
                el.style.width = nw + 'px'; currentStickers[idx].w = nw;
            }
            sx = p.clientX; sy = p.clientY;
        };
        window.onmouseup = window.ontouchend = () => { 
            if(isDrag || isRes) save();
            isDrag = isRes = false; 
        };
    }

    function deleteStk(idx) { currentStickers.splice(idx,1); save(); renderStickers(); }

    function renderGallery() {
        const g = document.getElementById('gallery');
        g.innerHTML = "";
        [...currentImages].reverse().forEach((url, i) => {
            const realIdx = currentImages.length - 1 - i;
            const d = document.createElement('div');
            d.className = "polaroid";
            d.innerHTML = `<img src="${url}">
                <button onclick="delImg(${realIdx})" style="display:${isEdit?'block':'none'}; position:absolute; top:0; right:0; background:red; color:#fff;">X</button>`;
            g.appendChild(d);
        });
    }

    async function save() { await db.collection('toys').doc(chipId).update({ images: currentImages, stickers: currentStickers }); }

    async function uploadImage() {
        const file = document.getElementById('fileInp').files[0];
        if(!file) return;
        document.getElementById('status').innerText = "SYS: UPLOADING...";
        const fd = new FormData();
        fd.append('file', file); fd.append('upload_preset', UPLOAD_PRESET);
        const res = await fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`, { method: 'POST', body: fd });
        const data = await res.json();
        currentImages.push(data.secure_url);
        await save(); renderGallery();
        document.getElementById('status').innerText = "SYS: DONE";
    }

    function delImg(idx) { if(confirm("XÓA?")) { currentImages.splice(idx,1); save(); renderGallery(); } }
</script>
</body>
</html>
